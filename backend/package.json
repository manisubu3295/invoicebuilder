    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.43.1",
