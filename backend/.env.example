PORT=5000
NODE_ENV=production

# PostgreSQL — create a DB first: psql -c "CREATE DATABASE akb_transport;"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=akb_transport
DB_USER=postgres
DB_PASSWORD=your_strong_db_password_here
# Set DB_SSL=true if using a hosted PostgreSQL (Render, Supabase, Railway, etc.)
DB_SSL=false

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=8h

# Email (Gmail SMTP — use an App Password, not your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=akbtransportlogistics@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=AKB Transport & Logistics <akbtransportlogistics@gmail.com>

# Admin seed (only used when users table is empty on first run)
ADMIN_EMAIL=akbtransportlogistics@gmail.com
ADMIN_PASSWORD=your_strong_admin_password_here
