PORT=5000
NODE_ENV=production

# JWT — use a long random string in production (openssl rand -base64 48)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (Gmail SMTP — use an App Password, not your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=akbtransportlogistics@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=AKB Transport & Logistics <akbtransportlogistics@gmail.com>

# CORS — only used in development; in production the frontend is served from the same origin
FRONTEND_URL=http://localhost:5173

# Admin seed credentials (only used when the database is empty on first run)
ADMIN_EMAIL=akbtransportlogistics@gmail.com
ADMIN_PASSWORD=change_this_strong_password
